{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pdf2qti Configuration",
  "description": "Configuration schema for pdf2qti quiz generation",
  "type": "object",
  "required": ["version", "sources"],
  "properties": {
    "version": {
      "type": "integer",
      "enum": [1],
      "description": "Config schema version (must be 1)"
    },
    "defaults": {
      "$ref": "#/definitions/defaults"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/source" }
    }
  },
  "definitions": {
    "optionRange": {
      "type": "object",
      "properties": {
        "min": { "type": "integer", "minimum": 2 },
        "max": { "type": "integer", "minimum": 2 }
      }
    },
    "counts": {
      "type": "object",
      "properties": {
        "tf": { "type": "integer", "minimum": 0 },
        "ma": { "type": "integer", "minimum": 0 },
        "mc": { "type": "integer", "minimum": 0 }
      }
    },
    "quiz": {
      "type": "object",
      "properties": {
        "titleTemplate": { "type": "string" },
        "descriptionTemplate": { "type": "string" },
        "counts": { "$ref": "#/definitions/counts" },
        "mcOptions": { "$ref": "#/definitions/optionRange" },
        "maOptions": { "$ref": "#/definitions/optionRange" }
      }
    },
    "generation": {
      "type": "object",
      "properties": {
        "stages": {
          "type": "array",
          "items": { "type": "string", "enum": ["tf", "ma", "mc"] }
        },
        "seed": { "type": "integer" },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "apiKeyEnv": { "type": "string" },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "maMaxCorrectDensity": { "type": "number", "minimum": 0, "maximum": 1 },
        "enforceUniqueOptionsPerQuestion": { "type": "boolean" },
        "requireSequentialNumbering": { "type": "boolean" },
        "requireExactlyOneCorrectForTfMc": { "type": "boolean" }
      }
    },
    "workflow": {
      "type": "object",
      "properties": {
        "outDir": { "type": "string" },
        "openReview": { "type": "boolean" },
        "reviewTarget": { "type": "string" },
        "requireApprovalBeforeBuild": { "type": "boolean" },
        "packageZip": { "type": "boolean" }
      }
    },
    "defaults": {
      "type": "object",
      "properties": {
        "quiz": { "$ref": "#/definitions/quiz" },
        "generation": { "$ref": "#/definitions/generation" },
        "validation": { "$ref": "#/definitions/validation" },
        "workflow": { "$ref": "#/definitions/workflow" }
      }
    },
    "source": {
      "type": "object",
      "required": ["id", "pdf"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "chapter": { "type": "integer", "minimum": 0 },
        "pdf": { "type": "string", "minLength": 1 },
        "quiz": { "$ref": "#/definitions/quiz" },
        "generation": { "$ref": "#/definitions/generation" },
        "validation": { "$ref": "#/definitions/validation" },
        "workflow": { "$ref": "#/definitions/workflow" }
      }
    }
  }
}
